# Base RPC (public is fine for light reads; use your own provider if you hit 429s)
RPC_URL=https://mainnet.base.org

# Deployer / contributor wallet (required for write flows only)
DEPLOYER_PRIVATE_KEY=0x...
CONTRIBUTOR_PRIVATE_KEY=0x...

# Borrower wallet (required for borrow/demo/agent-task flows)
BORROWER_PRIVATE_KEY=0x...

# Deployed contracts on Base (current demo deployment)
MEMORY_LENDING_ADDRESS=0x10c89c8f7991d72C7162EaC0CD272B75DB8EE469
OPERATOR_REGISTRY_ADDRESS=0xA8d755a65Eb7db887Da0e89FCd42867D1c6c4Cd7

# Canonical ERC-8004 registries on Base
IDENTITY_REGISTRY=0x8004A169FB4a3325136EB29fA0ceB6D2e539a432
REPUTATION_REGISTRY=0x8004BAa17C55a88189AE136b182e5fdA19dE9b63

# Operator IDs for wallets you control. Leave blank for read-only commands.
# The maintainer demo deployment currently uses contributor=1 and borrower=2.
CONTRIBUTOR_OPERATOR_ID=
BORROWER_OPERATOR_ID=

# ERC-8004 agent IDs that your wallets already own on the canonical Base registry.
# The repo does not mint agents for you. Leave blank for read-only commands.
# The maintainer demo deployment currently uses contributor=35279 and borrower=35280.
CONTRIBUTOR_AGENT_ID=
BORROWER_AGENT_ID=

# Anthropic API key (default eval provider)
ANTHROPIC_API_KEY=

# Venice API key (optional — use --venice flag for no-data-retention inference)
VENICE_API_KEY=

# Etherscan API key (optional, for contract verification on Basescan)
ETHERSCAN_API_KEY=

# Fragment server (dev only)
FRAGMENT_SERVER_PORT=3000

# Base RPC (Alchemy/Infura/public)
RPC_URL=https://mainnet.base.org

# Deployer / contributor wallet
DEPLOYER_PRIVATE_KEY=0x...
CONTRIBUTOR_PRIVATE_KEY=0x...

# Borrower wallet (can be same as deployer for testing)
BORROWER_PRIVATE_KEY=0x...

# Deployed contract addresses (fill after deploying to Base)
MEMORY_LENDING_ADDRESS=
OPERATOR_REGISTRY_ADDRESS=

# Canonical ERC-8004 registries on Base (defaults in config.ts)
IDENTITY_REGISTRY=0x8004A169FB4a3325136EB29fA0ceB6D2e539a432
REPUTATION_REGISTRY=0x8004BAa17C55a88189AE136b182e5fdA19dE9b63

# Operator IDs (fill after running register-operator)
CONTRIBUTOR_OPERATOR_ID=
BORROWER_OPERATOR_ID=

# Demo credit grants (operators start at the base credit line; raise when needed)
# Example:
# npm run set-credit-line -- $BORROWER_OPERATOR_ID 8

# ERC-8004 agent IDs (needed for giveFeedback on canonical reputation registry)
CONTRIBUTOR_AGENT_ID=
BORROWER_AGENT_ID=

# Anthropic API key (for evaluation harness)
ANTHROPIC_API_KEY=

# Etherscan API key (optional, for contract verification on Basescan)
ETHERSCAN_API_KEY=

# Fragment server (dev only)
FRAGMENT_SERVER_PORT=3000

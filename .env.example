# Base RPC (Alchemy/Infura/public)
RPC_URL=https://mainnet.base.org

# Deployer / contributor wallet
DEPLOYER_PRIVATE_KEY=0x...
CONTRIBUTOR_PRIVATE_KEY=0x...

# Borrower wallet (can be same as deployer for testing)
BORROWER_PRIVATE_KEY=0x...

# Deployed contracts on Base (current demo deployment)
MEMORY_LENDING_ADDRESS=0x392003B2c4D09fc9d68e52621BfB11c60b251E4d
OPERATOR_REGISTRY_ADDRESS=0x9C3cE38306bE382b5EC2E7B766FB1cd37C4a3306

# Canonical ERC-8004 registries on Base
IDENTITY_REGISTRY=0x8004A169FB4a3325136EB29fA0ceB6D2e539a432
REPUTATION_REGISTRY=0x8004BAa17C55a88189AE136b182e5fdA19dE9b63

# Operator IDs (current demo values — re-register if using your own wallets)
CONTRIBUTOR_OPERATOR_ID=1
BORROWER_OPERATOR_ID=2

# ERC-8004 agent IDs on canonical Base registry
CONTRIBUTOR_AGENT_ID=35279
BORROWER_AGENT_ID=35280

# Anthropic API key (for evaluation harness and sanitization)
ANTHROPIC_API_KEY=

# Etherscan API key (optional, for contract verification on Basescan)
ETHERSCAN_API_KEY=

# Fragment server (dev only)
FRAGMENT_SERVER_PORT=3000

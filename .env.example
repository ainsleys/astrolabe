# Sepolia RPC (Alchemy/Infura)
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY

# Deployer / contributor wallet
DEPLOYER_PRIVATE_KEY=0x...
CONTRIBUTOR_PRIVATE_KEY=0x...

# Borrower wallet (can be same as deployer for testing)
BORROWER_PRIVATE_KEY=0x...

# Deployed contract address (fill after deploy)
MEMORY_LENDING_ADDRESS=0x...

# ERC-8004 registries on Sepolia
IDENTITY_REGISTRY=0x8004A169FB4a3325136EB29fA0ceB6D2e539a432
REPUTATION_REGISTRY=0x8004BAa17C55a88189AE136b182e5fdA19dE9b63

# ERC-8004 agent IDs (fill after registration)
CONTRIBUTOR_AGENT_ID=
BORROWER_AGENT_ID=

# Anthropic API key (for evaluation)
ANTHROPIC_API_KEY=sk-ant-...

# Etherscan API key (for contract verification)
ETHERSCAN_API_KEY=

# Fragment server (dev only)
FRAGMENT_SERVER_PORT=3000

# Sepolia RPC (Alchemy/Infura)
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY

# Deployer / contributor wallet
DEPLOYER_PRIVATE_KEY=0x...
CONTRIBUTOR_PRIVATE_KEY=0x...

# Borrower wallet (can be same as deployer for testing)
BORROWER_PRIVATE_KEY=0x...

# Deployed contract address (fill after running Deploy.s.sol)
# Deploy.s.sol deploys MockIdentityRegistry, MockReputationRegistry,
# and MemoryLending on Sepolia. It also registers contributor (agent ID 1)
# and borrower (agent ID 2). All addresses and IDs are printed to stdout.
MEMORY_LENDING_ADDRESS=

# ERC-8004 mock registries (fill after running Deploy.s.sol)
# The canonical ERC-8004 registries are not on Sepolia, so Deploy.s.sol
# deploys minimal mock versions. Paste the printed addresses here.
IDENTITY_REGISTRY=
REPUTATION_REGISTRY=

# ERC-8004 agent IDs (fill after running Deploy.s.sol)
CONTRIBUTOR_AGENT_ID=
BORROWER_AGENT_ID=

# Anthropic API key (for evaluation harness)
ANTHROPIC_API_KEY=

# Etherscan API key (optional, for contract verification)
ETHERSCAN_API_KEY=

# Fragment server (dev only)
FRAGMENT_SERVER_PORT=3000
